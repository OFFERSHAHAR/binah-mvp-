# ============================================================
# בִּינָה (Binah) — Environment contract
# Copy to .env.local for local dev; set the same keys in your
# host's dashboard (e.g. Vercel → Settings → Environment Variables) for prod.
# NEVER commit real secrets. .env.local is gitignored.
# ============================================================

# --- Required ---------------------------------------------------------------

# Signs JWT access/refresh tokens. Use a long random string (min 32 chars).
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-min-32-chars

# --- Shared state (Upstash Redis) -------------------------------------------
# Powers sessions / rate-limit / CSRF across instances (required for scale).
# Without these the app falls back to in-memory (single instance only).
# Get them free at https://upstash.com -> create Redis DB -> REST section.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# Optional TCP URL (not used by the app's REST client, kept for reference/tooling):
REDIS_URL=rediss://default:your-token@your-db.upstash.io:6379

# --- Optional: Text-to-Speech (lesson builder narration) --------------------
# Without these, /api/tts returns 503 and the UI falls back gracefully.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Optional: real database (future - currently mock /api/data) ------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: realtime (needs a separately-hosted WebSocket server) --------
# Vercel serverless cannot host the WS server; point this at one if you deploy it.
NEXT_PUBLIC_WS_URL=

# --- Optional: monitoring ---------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
